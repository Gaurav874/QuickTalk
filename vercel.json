{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/backend/api/v1/$1" },
    { "src": "/api/message/(.*)", "dest": "/backend/api/message/$1" },
    { "src": "/socket.io/(.*)", "dest": "/backend/socket.io/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}