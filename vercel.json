{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/backend/index.js",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "src": "/api/message/(.*)",
      "dest": "/backend/index.js",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}